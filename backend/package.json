{
  "name": "ai-tools-reseller-backend",
  "version": "1.0.0",
  "description": "AI tools subscription reseller management backend",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema src/prisma/schema.prisma",
    "seed": "node src/prisma/seed.js",
    "check": "node --check src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "googleapis": "^144.0.0",
    "helmet": "^8.0.0",
    "imapflow": "^1.0.164",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@sentry/node": "^8.0.0",
    "express-rate-limit": "^7.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
