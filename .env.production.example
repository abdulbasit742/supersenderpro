# ---- SuperSender Pro - production env template ----
# Copy to .env and fill. Run `node scripts/deploy-doctor.js` to validate before deploy.

# Core
NODE_ENV=production
PORT=3000
SESSION_SECRET=               # REQUIRED: strong random (openssl rand -hex 32)

# Auth (Phase 2)
AUTH_JWT_SECRET=              # REQUIRED: strong random; falls back to SESSION_SECRET
AUTH_JWT_TTL_SEC=604800

# Data layer (Phase 1)
DB_DRIVER=json               # json | postgres
DATABASE_URL=                # required if DB_DRIVER=postgres

# Redis shared state (Phase 1) - set for multi-instance
REDIS_URL=

# Billing (Phase 2) - set to take live payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
BILLING_ENFORCE=warn         # warn first, then block
APP_URL=https://your-app

# Sales pipeline
SALES_PIPELINE_DRY_RUN=true  # flip to false + provide global.sendWhatsApp to send for real

# Alerts + observability (Phase 5)
ADMIN_ALERT_DRY_RUN=true
ADMIN_ALERT_RECIPIENTS=
SENTRY_DSN=
LOG_LEVEL=info

# Rate limits (Security) - override defaults if needed
RL_AUTH_LIMIT=10
RL_API_LIMIT=300

# Lifecycle (Phase 4)
SHUTDOWN_DRAIN_MS=3000
SHUTDOWN_DEADLINE_MS=15000
