# ============================================================================
# Unlimited Self-Hosted Media (Voice + Video) — example env
# Copy the vars you need into your real .env. Everything is DRY-RUN by default;
# nothing calls your GPU boxes until you flip the ALLOW_LIVE flags below.
# No API keys required — these run on YOUR own hardware (zero cost, unlimited).
# ============================================================================

# ---- Voice: Local TTS (GPT-SoVITS / Chatterbox / XTTS on PC #1) ----
# Pick this provider by setting VOICE_AI_DEFAULT_PROVIDER=local_tts
VOICE_AI_DEFAULT_PROVIDER=local_tts
VOICE_AI_ALLOW_LIVE_TTS=false        # set true to actually call the local server
VOICE_AI_DRY_RUN=true                # set false (with ALLOW_LIVE_TTS=true) to go live
LOCAL_TTS_URL=http://127.0.0.1:8001  # your local TTS HTTP server
LOCAL_TTS_PATH=/api/tts
LOCAL_TTS_ENGINE=gpt_sovits          # gpt_sovits | chatterbox | xtts | piper
LOCAL_TTS_VOICE=default
LOCAL_TTS_FORMAT=mp3
LOCAL_TTS_TIMEOUT_MS=120000

# ---- Video: Local generator (WanGP / ComfyUI / MoneyPrinterTurbo on PC #2) ----
VIDEO_AI_ENABLED=true
VIDEO_AI_DEFAULT_PROVIDER=local_video
VIDEO_AI_ALLOW_LIVE_GENERATE=false   # set true to actually call the local server
VIDEO_AI_DRY_RUN=true                # set false (with ALLOW_LIVE_GENERATE=true) to go live
VIDEO_AI_DEFAULT_RESOLUTION=720p
VIDEO_AI_DEFAULT_DURATION_SEC=8
LOCAL_VIDEO_URL=http://127.0.0.1:8002 # your local video HTTP server (PC #2)
LOCAL_VIDEO_PATH=/api/generate
LOCAL_VIDEO_ENGINE=wan               # wan | wan2.2 | ltx | hunyuan | comfyui | moneyprinter
LOCAL_VIDEO_FORMAT=mp4
LOCAL_VIDEO_TIMEOUT_MS=600000
