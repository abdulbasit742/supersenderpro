# =====================================================================
# SuperSender Pro — Complete .env Configuration Guide
# Copy this to .env and fill all values
# =====================================================================

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Secrets (auto-generated by: node scripts/generate-secrets.js) ─────
JWT_SECRET=CHANGE_ME_run_generate-secrets
SESSION_SECRET=CHANGE_ME_run_generate-secrets
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here
ADMIN_AUTH_PASSWORD=CHANGE_ME_admin_panel_password

# ── Database (PostgreSQL via Docker) ─────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_tools_db
DB_USER=admin
DB_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://admin:CHANGE_ME_strong_password_here@db:5432/ai_tools_db?schema=public

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
ZERO_TOUCH_ENABLE_BULL=true

# ── WhatsApp Bot (YOUR actual numbers) ────────────────────────────────
ADMIN_NUMBER=923001234567
# Format: 92 + number without 0 (e.g. 0300 → 92300)
WA_CUSTOMER_SESSION=customer-bot
WA_DEALER_SESSION=dealer-monitor
WA_ADMIN_SESSION=admin-alerts
WA_AUTO_CONNECT=true
WA_AUTH_ROOT=./.baileys-auth
# Group IDs from WhatsApp (invite link → get group ID)
SELLING_GROUPS=120363XXXXXXXXXX@g.us
CUSTOMER_GROUPS=120363XXXXXXXXXX@g.us

# ── Payment Accounts (YOUR actual accounts) ───────────────────────────
JAZZCASH_NUMBER=0300-XXXXXXX
EASYPAISA_NUMBER=0321-XXXXXXX
JAZZCASH_MERCHANT_NUMBER=0300-XXXXXXX
EASYPAISA_MERCHANT_NUMBER=0321-XXXXXXX
BANK_ACCOUNT=MCB-XXXXXXXXXX
BANK_NAME=MCB Bank
BANK_ACCOUNT_NUMBER=XXXXXXXXXX

# ── Email Parser (Gmail App Password) ────────────────────────────────
EMAIL_USER=yourstore@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_PAYMENT_PARSER_ENABLED=true
PAYMENT_CHECK_INTERVAL_MS=30000
SENDER_NUMBER_VERIFICATION=false

# ── Business Info ─────────────────────────────────────────────────────
BOT_NAME=AI Tools Store
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@yourdomain.com
LOW_STOCK_THRESHOLD=3

# ── AI / OpenAI (for smart agent replies) ────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXX
TAVILY_API_KEY=tvly-XXXXXXXXXX

# ── Google Sheets (optional) ──────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Social Media (optional) ───────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FB_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=

# ── n8n ──────────────────────────────────────────────────────────────
N8N_BASE_URL=http://n8n:5678
N8N_WEBHOOK_URL=http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=supersender123
N8N_WEBHOOK_SECRET=CHANGE_ME_run_generate-secrets

# ── Monitoring (optional) ────────────────────────────────────────────
SENTRY_DSN=

# ── WhatsApp Cloud API (optional) ────────────────────────────────────
WHATSAPP_SEND_PROVIDER=unofficial
WHATSAPP_CLOUD_API_ENABLED=false
WHATSAPP_CLOUD_DRY_RUN=true
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_VERIFY_TOKEN=

# ── Agentic AI ───────────────────────────────────────────────────────
AGENTIC_SKILLS_DRY_RUN_DEFAULT=true
AGENTIC_MISSIONS_REQUIRE_APPROVAL=true

# ── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001