# Sales & Pipeline (deal-closing) module - copy needed keys into your .env
# Safe by default: dry-run ON (messages prepared, not sent), admin required for writes.

SALES_PIPELINE_ENABLED=true
SALES_PIPELINE_DRY_RUN=true
SALES_PIPELINE_REQUIRE_ADMIN=true
# Set a strong secret to allow write endpoints (falls back to ADMIN_TOKEN / CHANNEL_ADMIN_SECRET)
SALES_PIPELINE_ADMIN_SECRET=

# Money / documents
SALES_PIPELINE_CURRENCY=PKR
SALES_PIPELINE_TAX_PERCENT=0
SALES_PIPELINE_QUOTE_PREFIX=QUO
SALES_PIPELINE_INVOICE_PREFIX=INV
SALES_PIPELINE_INVOICE_DUE_DAYS=7

# Automation cadences
# Hours after entering a stage (no reply) to fire follow-ups
SALES_PIPELINE_FOLLOWUP_HOURS=24,72,168
# Minutes after a cart goes idle to fire recovery nudges
SALES_PIPELINE_CART_STEPS_MIN=60,1440,4320
